pipeline {
    agent any

    environment {
        PROJECT_NAME = "simpleweb_v2"
        BASE_DIR     = "/opt/projects"
        PROJECT_DIR  = "${BASE_DIR}/${PROJECT_NAME}"
        NGINX_DIR    = "/var/www/html"
    }

    stages {

        stage('Setup Permissions') {
            steps {
                sh '''
                sudo mkdir -p $BASE_DIR
                sudo chown -R jenkins:jenkins $BASE_DIR
                '''
            }
        }

        stage('Clean Old Deployment') {
            steps {
                sh '''
                sudo rm -rf $PROJECT_DIR
                sudo mkdir -p $PROJECT_DIR
                sudo chown -R jenkins:jenkins $PROJECT_DIR
                '''
            }
        }

        stage('Copy Code to Target') {
            steps {
                sh '''
                cp simpleweb/index.html $PROJECT_DIR/
                '''
            }
        }

        stage('Deploy to Nginx') {
            steps {
                sh '''
                sudo cp $PROJECT_DIR/index.html $NGINX_DIR/
                '''
            }
        }

        stage('Reload Nginx') {
            steps {
                sh '''
                sudo systemctl daemon-reload
                sudo systemctl reload nginx
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                sleep 2
                STATUS=$(curl -o /dev/null -s -w "%{http_code}" http://localhost)

                if [ "$STATUS" -eq 200 ]; then
                    echo "✅ Application is UP"
                else
                    echo "❌ Application is DOWN"
                    exit 1
                fi
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Deployment Successful & Verified!"
        }
        failure {
            echo "❌ Deployment Failed!"
        }
    }
}
